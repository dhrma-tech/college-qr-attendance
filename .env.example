# ScanRoll Environment Variables
# Copy this file to .env.local when you want to connect Supabase.
# The app works in demo mode when Supabase values are empty.

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase project URL (PUBLIC)
# Find it in Supabase: Project Settings -> API -> Project URL
# This is safe to expose to the client-side code.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key (PUBLIC)
# Find it in Supabase: Project Settings -> API -> anon public
# This is safe to expose to the client-side code.
# Limited to operations allowed by RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (SERVER-ONLY - SECRET)
# Find it in Supabase: Project Settings -> API -> service_role
# ⚠️ CRITICAL: This key bypasses all RLS policies and has full database access.
# ⚠️ NEVER prefix this with NEXT_PUBLIC_ - it must remain server-side only.
# ⚠️ NEVER commit this value to version control.
# ⚠️ NEVER expose this in client-side code or browser logs.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME=ScanRoll

# Minimum attendance percentage before a student is marked at risk
NEXT_PUBLIC_ATTENDANCE_THRESHOLD=75

# QR token refresh time in seconds
NEXT_PUBLIC_QR_ROTATION_INTERVAL=30

# Classroom geofence radius in meters
NEXT_PUBLIC_GEOFENCE_RADIUS=100

# =============================================================================
# DEMO MODE NOTES
# =============================================================================
# 
# When NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are empty:
# - The app runs in demo mode with mock data
# - No real authentication or database operations
# - All data is stored in browser localStorage only
# - Safe for development and testing
# - NOT suitable for production use
#
# To connect to a real Supabase backend:
# 1. Fill in all Supabase variables above
# 2. Run the database migrations from supabase/migrations/
# 3. Create real users and populate the users table
# 4. Review SECURITY.md before production use
#
